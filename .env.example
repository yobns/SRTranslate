# Frontend Configuration (Next.js)
# =====================================

# Python backend URL - REQUIRED for production performance!
# Without this, Next.js will spawn Python processes synchronously (VERY SLOW)
# Production: https://translatesrt.onrender.com
PY_BACKEND_URL=

# Python command (default: python3)
PYTHON_CMD=python3

# Backend Configuration (Python API)
# =====================================

# Frontend URL for CORS (optional)
# Production: https://srtranslater.vercel.app
FRONTEND_URL=

# Performance Settings
# ====================

# Enable fast mode (recommended for production)
FAST_MODE=1

# Translation timeout in seconds (default: 50)
TRANSLATE_TIMEOUT=50

# Number of concurrent translation requests (default: 15)
# Higher = faster but may hit rate limits
# Recommended: 10-20
TRANSLATE_CONCURRENCY=15

# Group settings (for context-aware translation)
# ==============================================

# Maximum characters per translation group (default: 800)
# Smaller = more parallel requests = faster
GROUP_MAX_CHARS=800

# Maximum subtitle blocks per group (default: 4)
GROUP_MAX_BLOCKS=4

# Maximum gap between subtitles in a group in milliseconds (default: 1500)
GROUP_MAX_GAP_MS=1500

# Cache threshold for using cached translations (default: 0.4)
CACHE_GROUP_THRESHOLD=0.4

# Translation cache settings
# =========================

# Enable disk cache (default: 1)
TRANSLATE_CACHE=1

# Cache file path (default: .translate_cache.sqlite)
TRANSLATE_CACHE_PATH=.translate_cache.sqlite

# Production Environment Variables
# Copy these to your deployment platform (Vercel, Render, etc.)

# ============================================
# CRITICAL - Must be set for good performance
# ============================================

# Python Backend URL (REQUIRED for production!)
# Without this, translations will be VERY SLOW
PY_BACKEND_URL=https://translatesrt.onrender.com

# ============================================
# Backend Configuration (on Render)
# ============================================

# Frontend URL for CORS
FRONTEND_URL=https://srtranslater.vercel.app

# Performance Settings
FAST_MODE=1
TRANSLATE_TIMEOUT=50
TRANSLATE_CONCURRENCY=15
GROUP_MAX_CHARS=800
GROUP_MAX_BLOCKS=4
GROUP_MAX_GAP_MS=1500

# ============================================
# Vercel Deployment
# ============================================
# 1. Go to https://vercel.com/dashboard
# 2. Select your project
# 3. Settings → Environment Variables
# 4. Add: PY_BACKEND_URL = https://translatesrt.onrender.com
# 5. Save and redeploy

# ============================================
# Render Deployment
# ============================================
# Already configured in render.yaml
# Just push this code to GitHub
